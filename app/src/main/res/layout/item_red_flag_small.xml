<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="8dp">

    <View
        android:id="@+id/severityIndicator"
        android:layout_width="4dp"
        android:layout_height="24dp"
        android:background="@android:color/holo_red_light"
        android:layout_marginEnd="12dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/flagSummary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Student: BIT/001 - Mismatch"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/flagTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2 mins ago"
            android:textColor="@color/text_grey"
            android:textSize="11sp" />
    </LinearLayout>

    <ImageView
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@android:drawable/ic_media_play"
        android:contentDescription="View detail"
        android:layout_marginStart="8dp"
        app:tint="@color/text_grey" />

</LinearLayout>
