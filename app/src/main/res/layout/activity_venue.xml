<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    tools:context=".VenueActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="24dp">

        <!-- Header Block -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Registered Venues"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/venueCountTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Active active geofence clusters"
                android:textColor="@color/text_grey"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Empty State View (Toggled programmatically if data is missing) -->
        <TextView
            android:id="@+id/noVenuesTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No spatial boundaries registered yet."
            android:textColor="@color/text_grey"
            android:gravity="center"
            android:padding="40dp"
            android:visibility="gone" />

        <!-- Core Recycler View List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/venuesRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="vertical"
            android:clipToPadding="false"
            android:paddingBottom="88dp"
            tools:listitem="@layout/item_venue_card" />

    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/addVenueFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="96dp"
        android:contentDescription="Add New Venue"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="@color/primary_light"
        app:tint="@color/white" />

    <!-- Shared Bottom Navigation Layer -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/card_dark"
        app:itemIconTint="@color/primary_light"
        app:itemTextColor="@color/white"
        app:menu="@menu/menu_admin_nav"
        app:labelVisibilityMode="labeled" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>